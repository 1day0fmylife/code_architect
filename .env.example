# Copy to .env and replace every change-me value before production use.

# Postgres service password used by docker-compose.yml.
POSTGRES_PASSWORD=change-me

# HTTP API bearer token for /workflow/* and /memory/*.
WEB_AUTH_TOKEN=change-me-web-token
WEB_AUTH_DISABLED=false

# Leave empty to disable Telegram polling.
# Use @BotFather to create a bot token and a user-info bot to get allowed IDs.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=

# LLM backend.
DEFAULT_LLM_BACKEND=ollama
DEFAULT_MODEL=qwen2.5-coder:7b

# Code engine runtime.
CODE_ENGINE=opencode
OPENCODE_BIN=opencode
CODEX_BIN=codex
CODE_ENGINE_TIMEOUT_SECONDS=1800
REQUIRE_APPROVAL_FOR_CODE=true
REQUIRE_APPROVAL_FOR_SHELL=true
